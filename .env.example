# Copy to .env.local for local development

# Python screener (set in GitHub Secrets for CI)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxx
EMAIL_RECIPIENTS=you@gmail.com

# GitHub raw CDN base for chart image URLs in emails
# Replace OWNER with your GitHub username
GITHUB_RAW_BASE=https://raw.githubusercontent.com/OWNER/stock-screener/main

# Dashboard URL (set after Cloudflare Pages deployment)
DASHBOARD_URL=https://stock-screener.pages.dev

# React frontend (Vite)
# In dev, points to the local results file served by vite dev server
VITE_RESULTS_URL=/results/latest.json
# In production, points to GitHub raw CDN
# VITE_RESULTS_URL=https://raw.githubusercontent.com/OWNER/stock-screener/main/results/latest.json
